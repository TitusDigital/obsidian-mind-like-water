{
	"name": "obsidian-mind-like-water",
	"version": "1.0.6",
	"description": "GTD-powered task management for Obsidian",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "vitest run && tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"test": "vitest run",
		"lint": "eslint ."
	},
	"keywords": [
		"obsidian",
		"gtd",
		"task-management",
		"productivity"
	],
	"license": "0-BSD",
	"devDependencies": {
		"@codemirror/state": "^6.5.4",
		"@codemirror/view": "^6.39.15",
		"@eslint/js": "9.30.1",
		"@eslint/json": "^1.0.1",
		"@types/node": "^16.11.6",
		"esbuild": "0.25.5",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "14.0.0",
		"jiti": "2.6.1",
		"tslib": "2.4.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.35.1",
		"vitest": "^4.0.18"
	},
	"dependencies": {
		"obsidian": "latest",
		"rrule": "^2.8.1"
	}
}
